---
import type { ImageMetadata } from "astro";
import { validateImageSource } from "@/adapters/image/image.adapter";
import ImagenBase from "./ImagenBase.astro";

interface Props {
	src: string | ImageMetadata;
	alt: string;
	[rest: string]: unknown;
}

const { src, alt, ...rest } = Astro.props as Props;
const safeSrc = validateImageSource(src);
---

<ImagenBase src={safeSrc} alt={alt} {...rest} />
