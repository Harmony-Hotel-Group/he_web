DEBUG=false

# ==================================================
#      CONFIGURACIÓN DE ENDPOINTS
# ==================================================
#
# URL base para la API.
# Debe ser el dominio principal (ej: http://localhost:3000), ya que el servicio
# de API añade automáticamente el path "/api".
# El prefijo PUBLIC_ es REQUERIDO por Astro para exponer la variable al cliente.
PUBLIC_API_BASE_URL="http://localhost:3000"
STATUS_CHECK_INTERVAL_MINUTES=5

# ==================================================
#      CONFIGURACIÓN DE CORREO (MAILGUN)
# ==================================================
#
# Llave de API de Mailgun para el envío de correos.
MAILGUN_API_KEY=your_key
# Dominio verificado en Mailgun (ej: mg.midominio.com).
MAILGUN_DOMAIN=mg.yourdomain.com
# Correo electrónico que recibirá las notificaciones del sistema (ej: reservas).
ADMIN_EMAIL=admin@example.com
# Correo electrónico que aparecerá como remitente en los correos enviados.
SENDER_EMAIL=noreply@example.com


# ==================================================
#      CONFIGURACIÓN DE CACHÉ
# ==================================================
#
# Llave privada para asegurar los endpoints administrativos de caché (/api/admin/cache).
# Genera una llave segura usando: node tools/generate_secret.js
CACHE_PRIVATE_KEY=


# ==================================================
#      CONFIGURACIÓN DE LOGS PARA DESARROLLO
# ==================================================
#
# Este archivo controla el comportamiento del servicio de logger (`src/services/logger.ts`).
# Los cambios aquí requieren que reinicies el servidor de desarrollo de Astro.

# --- Control Global ---
# Establece esto en `false` para deshabilitar TODOS los logs de la aplicación.
# Cualquier otro valor (o si la línea está comentada) los mantendrá habilitados.
# Ejemplo: LOG_ENABLED=false
LOG_ENABLED=true

# --- Filtrado por Contexto ---
# Especifica qué contextos de log quieres ver, separados por comas.
# Un contexto es el string que se pasa como primer argumento a `log()`, `warn()`, o `error()`.
#
# - Para ver TODOS los logs, deja el valor como `*` o comenta la línea.
#   LOG_CONTEXTS=*
#
# - Para ver logs solo de ciertos contextos, enlístralos.
#   Ejemplo: Para ver solo logs de la API y del modal de booking.
#   LOG_CONTEXTS=Api,ModalBookingGroup
#
# - Ejemplo: Para ver solo los logs del sistema de traducción.
LOG_CONTEXTS=*

# ==================================================
#      CONFIGURACIÓN DE ANALYTICS
# ==================================================
#
# Token de Mixpanel para analytics (se expone al cliente)
PUBLIC_MIXPANEL_TOKEN=

# ==================================================
#      CONFIGURACIÓN DE WHATSAPP
# ==================================================
#
# Número de WhatsApp para reservas (formato internacional sin +)
WHATSAPP_NUMBER=593978888020
# Token de acceso de la API de Meta para WhatsApp Business
WHATSAPP_TOKEN=
# ID del número de teléfono de WhatsApp Business
WHATSAPP_PHONE_ID=
# Número de teléfono de destino para mensajes (formato internacional)
WHATSAPP_DESTINATION_PHONE=

# ==================================================
#      CONFIGURACIÓN DE WEBHOOK
# ==================================================
#
# URL para recibir notificaciones de reserva vía webhook (POST JSON)
BOOKING_WEBHOOK_URL=

# ==================================================
#      CONFIGURACIÓN DE TELEGRAM
# ==================================================
#
# Token del bot de Telegram (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=
# Chat ID donde se enviarán los mensajes
TELEGRAM_CHAT_ID=

# ==================================================
#      CONFIGURACIÓN DE ERP
# ==================================================
#
# URL base del sistema ERP (se expone al cliente)
PUBLIC_ERP_BASE_URL=
# Modo del ERP: 'mock' para desarrollo local, 'real' para producción
PUBLIC_ERP_MODE=mock
# Tiempo de espera para solicitudes al ERP en milisegundos
PUBLIC_ERP_TIMEOUT_MS=5000

# ==================================================
#      CONFIGURACIÓN DE SEGURIDAD
# ==================================================
#
# Clave secreta para encriptación de sesiones (generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=
# Clave secreta para tokens CSRF (generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CSRF_SECRET=
# URL del sitio para validación de origen
SITE_URL=https://hotelensuenos.com
# Entorno (development, staging, production)
NODE_ENV=development

# ==================================================
#      CONFIGURACIÓN DE RATE LIMITING
# ==================================================
#
# Habilitar rate limiting (true/false)
RATE_LIMIT_ENABLED=true
# Límite por defecto de peticiones por ventana
RATE_LIMIT_DEFAULT=100
# Ventana de tiempo por defecto en segundos
RATE_LIMIT_WINDOW=60