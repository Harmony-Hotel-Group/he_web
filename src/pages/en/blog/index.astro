---
// src/pages/blog/index.astro
// Listado del blog / guía turística

import BaseLayout from "@/layouts/BaseLayout.astro";
import { Translations } from "@/i18n/translation.ts";
import { api } from "@/services/api.ts";
import type { SiteConfig } from "@/types/config";

const lang = Astro.url.pathname.startsWith("/en") ? "en" : "es";
const t = Translations(lang);
const config = (await api.fetch("config", { params: { lang } })) as SiteConfig;

// Importar posts del blog
const allPosts = Object.values(
	import.meta.glob<{ frontmatter: Record<string, unknown> }>("../../content/blog/*.md", { eager: true })
);

const posts = allPosts
	.map((post) => ({
		title: lang === "en" && post.frontmatter.titleEn ? post.frontmatter.titleEn : post.frontmatter.title,
		description: lang === "en" && post.frontmatter.descriptionEn ? post.frontmatter.descriptionEn : post.frontmatter.description,
		date: post.frontmatter.date,
		category: post.frontmatter.category,
		tags: post.frontmatter.tags,
		slug: post.frontmatter.slug,
	}))
	.sort((a, b) => new Date(b.date as string).getTime() - new Date(a.date as string).getTime());
---

<BaseLayout titleKey="nav.blog" lang={lang} config={config}>
	<section class="bg-gray-100/90 backdrop-blur border-b border-gray-200">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-[6.5rem] pb-10">
			<h1 class="text-3xl md:text-4xl font-serif text-primary font-bold mb-2">
				{lang === "es" ? "Blog & Guía Turística" : "Blog & Travel Guide"}
			</h1>
			<p class="text-gray-600 max-w-2xl">
				{lang === "es"
					? "Descubre Cuenca y sus alrededores con nuestras guías y consejos de viaje."
					: "Discover Cuenca and its surroundings with our travel guides and tips."}
			</p>
		</div>
	</section>

	<section class="py-16 md:py-20 bg-white">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			{posts.length === 0 ? (
				<p class="text-gray-500 text-center py-10">
					{lang === "es" ? "Próximamente artículos nuevos." : "New articles coming soon."}
				</p>
			) : (
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
					{posts.map((post) => (
						<a
							href={`/blog/${post.slug}`}
							class="group block bg-white border border-gray-200 rounded-lg overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-300"
						>
							<div class="p-6">
								{post.category && (
									<span class="inline-block text-xs font-bold text-accent uppercase tracking-wide mb-2">
										{post.category}
									</span>
								)}
								<h2 class="text-xl font-serif text-primary font-semibold mb-3 group-hover:text-accent transition-colors">
									{post.title}
								</h2>
								<p class="text-gray-600 text-sm mb-4 line-clamp-3">
									{post.description}
								</p>
								<div class="flex items-center justify-between">
									<span class="text-xs text-gray-400">
										{new Date(post.date as string).toLocaleDateString(lang === "es" ? "es-EC" : "en-US", {
											year: "numeric",
											month: "long",
											day: "numeric",
										})}
									</span>
									{post.tags && (
										<div class="flex gap-1">
											{(post.tags as string[]).slice(0, 2).map((tag) => (
												<span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded">
													{tag}
												</span>
											))}
										</div>
									)}
								</div>
							</div>
						</a>
					))}
				</div>
			)}
		</div>
	</section>
</BaseLayout>
