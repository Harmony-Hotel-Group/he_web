---
// src/components/organisms/booking/BookingForm.astro
import Button from "@/components/atoms/button/Button.astro";
import CSRFToken from "@/components/atoms/CSRFToken.astro";
import Icono from "@/components/atoms/Icono.astro";
import Label from "@/components/atoms/Label.astro";
import TextAreaInput from "@/components/atoms/TextAreaInput.astro";
import BookingSummaryModal from "@/components/molecules/booking/BookingSummaryModal.astro";
import DatePickerField from "@/components/molecules/forms/DatePickerField.astro";
import DropDownField from "@/components/molecules/forms/DropdownField.astro";
import NumberField from "@/components/molecules/forms/NumberField.astro";
import SwitchField from "@/components/molecules/forms/SwitchField.astro";
import { Translations } from "@/i18n/translation.ts";
import Grid from "@/layouts/GridLayout.astro";
import Row from "@/layouts/Row.astro";
import type { SiteConfig } from "@/types/config";
import { range } from "@/utils/math.ts";
import BookingVehicleSection from "./BookingVehicleSection.astro";

interface Props {
	lang: string;
	config: SiteConfig;
}
const { lang, config } = Astro.props;

const t = Translations(lang);

const adultsOptions = range(1, 9).map((i, index, array) => {
	if (index === array.length - 1) {
		return {
			value: "group",
			label: t("booking.dropdown.optGroup"),
		};
	}
	return {
		value: `${i}`,
		label: `${t("booking.dropdown.optAdults", {
			i: i,
			s: i > 1 ? "s" : "",
		})}`,
	};
});

const childrenOptions = range(0, 8).map((i) => {
	return {
		value: `${i}`,
		label: `${t("booking.dropdown.optChildren", {
			i: i === 0 ? "Sin" : i,
			s: i === 0 ? "s" : i > 1 ? "s" : "",
		})}`,
	};
});

const roomsOptions = range(1, 5).map((i) => {
	return {
		value: `${i}`,
		label: `${t("booking.dropdown.optRooms", {
			i: i,
			s: i > 1 ? "es" : "",
		})}`,
	};
});

const distributionOptions = [
	{ value: "shared_beds", label: "Camas Compartidas" },
	{ value: "shared_rooms", label: "Habitaciones Compartidas" },
	{ value: "individual_rooms", label: "Habitaciones Individuales" },
];

const whatsappNumber = config?.contactInfo?.whatsapp ?? "";
const email = config?.contactInfo?.email ?? "";
---

<form
  id="booking-form"
  method="post"
  class="rounded-xl space-y-3"
  data-lang={lang}
  data-whatsapp={whatsappNumber}
  data-email={email}
>
  <!-- CSRF Token -->
  <CSRFToken />
  
  <!-- Standard Fields Container -->
  <div id="standard-fields">
    <Grid cols={5}>
      <div data-col-span="2">
        <DatePickerField
          fieldId="dateRange"
          name="dateRange"
          lblKey="booking.dateRange.title"
          icon="form/calendar"
          lang={lang}
        />
      </div>
      <DropDownField
        fieldId="adults"
        name="adults"
        initialValue={2}
        icon="form/adult"
        lblKey="booking.dropdown.lblAdults"
        lang={lang}
        options={adultsOptions}
      />

      <DropDownField
        fieldId="children"
        name="children"
        icon="form/teen"
        lblKey="booking.dropdown.lblChildren"
        lang={lang}
        options={childrenOptions}
      />

      <DropDownField
        fieldId="rooms"
        name="rooms"
        icon="form/bed"
        lblKey="booking.dropdown.lblRooms"
        lang={lang}
        options={roomsOptions}
      />
    </Grid>
  </div>

  <!-- Group Fields Container (Hidden by default) -->
  <div id="group-fields" class="hidden space-y-4">
    <div class="flex justify-between items-center mb-2">
      <h3
        class="text-lg font-semibold text-gray-800 dark:text-gray-100 flex items-center gap-2"
      >
        <Icono name='form/group' size="lg" />
        {t("booking.group.title") || "Reserva Grupal"}
      </h3>
      <button
        type="button"
        id="btn-cancel-group"
        class="text-sm text-red-500 hover:text-red-700 font-medium"
      >
        ✕ Cancelar Grupo
      </button>
    </div>

    <Grid cols={3} autoAdjust={false} gap={4}>
      <DatePickerField
        fieldId="dateRangeGroup"
        name="dateRangeGroup"
        lblKey="booking.dateRange.title"
        lang={lang}
        syncGroup="booking"
      />

      <NumberField
        fieldId="groupAdults"
        name="groupAdults"
        lblKey="booking.group.adults"
        lang={lang}
        icon="form/adult"
        min={8}
        value={8}
      />

      <NumberField
        fieldId="groupTeens"
        name="groupTeens"
        lblKey="booking.group.teens"
        lang={lang}
        icon="form/teen"
        min={0}
      />

      <NumberField
        fieldId="groupKids"
        name="groupKids"
        lblKey="booking.group.kids"
        lang={lang}
        icon="form/child"
        min={0}
      />

      <NumberField
        fieldId="groupInfants"
        name="groupInfants"
        lblKey="booking.group.infants"
        lang={lang}
        icon="form/baby"
        min={0}
      />

      <DropDownField
        fieldId="distributionType"
        name="distributionType"
        icon="form/bed"
        lblKey="Tipo de Distribución"
        lang={lang}
        options={distributionOptions}
      />
    </Grid>
  </div>

  <!-- Switches -->
  <Row>
    <SwitchField
      fieldId="breakfast"
      name="breakfast"
      lblKey="booking.switch.breakfast"
      lang={lang}
      checked
      icon="form/breakfast"
    />
    <SwitchField
      fieldId="vehicle"
      name="vehicle"
      lblKey="booking.switch.vehicle"
      lang={lang}
      icon="form/vehicle"
    />
    <SwitchField
      fieldId="special_request"
      name="special_request"
      lblKey="booking.switch.special_request"
      lang={lang}
      icon="form/request"
    />
  </Row>

  <!-- Sección de Vehículos (oculta inicialmente) -->
  <div id="vehicle-section" class="hidden">
    <BookingVehicleSection lang={lang} config={config} />
  </div>

  <div id="special_request-section" class="hidden">
    <Label
      forId="groupNotes"
      lang={lang}
      lblKey="booking.group.notes"
      classes="pr-5"
    />
    <TextAreaInput
      id="groupNotes"
      name="groupNotes"
      keyPlaceholder="booking.group.notesPlaceholder"
      lang={lang}
    />
  </div>

  <div class="text-center pt-4">
    <Button
      _id="btnSubmit"
      type="button"
      lblKey="booking.btn.search"
      lang={lang}
      variant="accent"
      className="w-full md:w-auto px-12"
      icon="search"
      color="#FFFFFF"
    />
  </div>

  <!-- Booking Summary Modal -->
  <BookingSummaryModal lang={lang} />

  <script>
    import { actions } from "astro:actions";
    import { buildBookingMessage } from "@/domain/booking/buildBookingMessage";

    document.addEventListener("astro:page-load", async () => {
      const form: HTMLFormElement = document.getElementById(
        "booking-form",
      ) as HTMLFormElement;
      if (!form) return;
      if (form.dataset.initialized === "true") return;
      form.dataset.initialized = "true";

      const lang = form.dataset.lang || "es";

      const bookingBar = form.closest("#booking-bar");
      const vehicleSection = document.getElementById("vehicle-section");

      // Elements for Group Mode
      const standardFields = document.getElementById("standard-fields");
      const groupFields = document.getElementById("group-fields");
      const adultsDropdown = document.getElementById(
        "adults",
      ) as HTMLSelectElement;
      const btnCancelGroup = document.getElementById("btn-cancel-group");
      const specialRequestSection = document.getElementById(
        "special_request-section",
      );
      const dateRangeStandard = document.getElementById(
        "dateRange",
      ) as HTMLInputElement;
      const dateRangeGroup = document.getElementById(
        "dateRangeGroup",
      ) as HTMLInputElement;

      // Toggle Vehicle Section - Listen to switch:change event
      if (vehicleSection) {
        const handleVehicleSwitch = (e: Event) => {
          const detail = (e as CustomEvent).detail;
          console.log("[BookingForm] Vehicle switch event received:", detail);
          if (detail && detail.name === 'vehicle') {
            vehicleSection.classList.toggle("hidden", !detail.checked);
            bookingBar?.classList.toggle("max-h-[80vh]", detail.checked);
            bookingBar?.classList.toggle("overflow-y-auto", detail.checked);
          }
        };
        
        form.addEventListener("switch:change", handleVehicleSwitch);
        
        // Set initial state based on vehicle switch checked attribute
        setTimeout(() => {
          const vehicleSwitch = form.querySelector('[data-switch-name="vehicle"]') as HTMLButtonElement;
          if (vehicleSwitch) {
            const initialVehicleChecked = vehicleSwitch.getAttribute("aria-checked") === "true";
            console.log("[BookingForm] Initial vehicle checked:", initialVehicleChecked);
            if (initialVehicleChecked) {
              vehicleSection.classList.remove("hidden");
            }
          }
        }, 100);
      }

      // Toggle Special Request Section - Listen to switch:change event
      if (specialRequestSection) {
        const handleSpecialRequestSwitch = (e: Event) => {
          const detail = (e as CustomEvent).detail;
          console.log("[BookingForm] Special request switch event received:", detail);
          if (detail && detail.name === 'special_request') {
            specialRequestSection.classList.toggle("hidden", !detail.checked);
          }
        };
        
        form.addEventListener("switch:change", handleSpecialRequestSwitch);
        
        // Set initial state based on special_request switch checked attribute
        setTimeout(() => {
          const specialSwitch = form.querySelector('[data-switch-name="special_request"]') as HTMLButtonElement;
          if (specialSwitch) {
            const initialSpecialChecked = specialSwitch.getAttribute("aria-checked") === "true";
            console.log("[BookingForm] Initial special_request checked:", initialSpecialChecked);
            if (initialSpecialChecked) {
              specialRequestSection.classList.remove("hidden");
            }
          }
        }, 100);
      }

      // Group Mode Logic
      function toggleGroupMode(isGroup: boolean) {
        if (isGroup) {
          standardFields?.classList.add("hidden");
          groupFields?.classList.remove("hidden");
          // Sync date from standard to group
          if (dateRangeStandard && dateRangeGroup && dateRangeStandard.value) {
            // Try to sync values if feasible.
            // Note: DatePicker internal state might need more work to sync perfectly if it has JS attached,
            // but basic value copy helps.
            dateRangeGroup.value = dateRangeStandard.value;
          }
        } else {
          groupFields?.classList.add("hidden");
          standardFields?.classList.remove("hidden");
          if (dateRangeStandard && dateRangeGroup && dateRangeGroup.value) {
            dateRangeStandard.value = dateRangeGroup.value;
          }
          // Reset Adults dropdown
          if (adultsDropdown) adultsDropdown.value = "2";
        }
      }

      if (adultsDropdown) {
        adultsDropdown.addEventListener("change", (e) => {
          const target = e.target as HTMLSelectElement;
          toggleGroupMode(target.value === "group");
        });
      }

      if (adultsDropdown?.value === "group") {
        toggleGroupMode(true);
      }

      if (btnCancelGroup) {
        btnCancelGroup.addEventListener("click", () => {
          toggleGroupMode(false);
        });
      }

      if (dateRangeGroup && dateRangeStandard) {
        dateRangeGroup.addEventListener("change", () => {
          if (!groupFields?.classList.contains("hidden")) {
            dateRangeStandard.value = dateRangeGroup.value;
          }
        });
      }

      function clearValidationErrors() {
        form
          .querySelectorAll('[id^="error_"]')
          .forEach((el) => el.classList.add("hidden"));
        form
          .querySelectorAll(".border-red-500")
          .forEach((el) => el.classList.remove("border-red-500"));
      }

      function handleValidationErrors(
        errors: Array<{ path: string[]; message: string }>,
      ) {
        for (const fieldError of errors) {
          const fieldName = fieldError.path[0];
          const inputElement = document.getElementById(fieldName);
          const errorElement = document.getElementById(`error_${fieldName}`);

          if (inputElement) {
            inputElement.classList.add("border-red-500");
          }
          if (errorElement) {
            errorElement.textContent = fieldError.message;
            errorElement.classList.remove("hidden");
          }
        }
      }

      function validateForm(): boolean {
        let isValid = true;
        clearValidationErrors();

        const isGroupMode = !groupFields?.classList.contains("hidden");

        if (isGroupMode) {
          // Validate Group Date
          const dateInput = document.getElementById(
            "dateRangeGroup",
          ) as HTMLInputElement;
          if (!dateInput?.value || dateInput.value.trim() === "") {
            const errorElement = document.getElementById(
              "error_dateRangeGroup",
            );
            if (errorElement) {
              errorElement.classList.remove("hidden");
              errorElement.innerText = "Requerido";
            }
            if (dateInput) dateInput.classList.add("border-red-500");
            isValid = false;
          }

          // Validate Adults Min 8
          const groupAdults = document.getElementById(
            "groupAdults",
          ) as HTMLInputElement;
          if (!groupAdults?.value || parseInt(groupAdults.value) < 8) {
            const errorElement = document.getElementById("error_groupAdults");
            if (errorElement) {
              errorElement.classList.remove("hidden");
              errorElement.innerText = "Mínimo 8";
            }
            if (groupAdults) groupAdults.classList.add("border-red-500");
            isValid = false;
          }
        } else {
          // Validate Standard Date
          const dateRangeInput = document.getElementById(
            "dateRange",
          ) as HTMLInputElement;
          if (!dateRangeInput?.value || dateRangeInput.value.trim() === "") {
            const errorElement = document.getElementById("error_dateRange");
            if (errorElement) {
              errorElement.classList.remove("hidden");
            }
            if (dateRangeInput) {
              dateRangeInput.classList.add("border-red-500");
            }
            isValid = false;
          }
        }

        if (!isValid) {
          const firstError = form.querySelector('[id^="error_"]:not(.hidden)');
          firstError?.scrollIntoView({ behavior: "smooth", block: "center" });
        }

        return isValid;
      }

      async function checkAvailability(dateRange: string, roomId?: string): Promise<{ available: boolean; message: string }> {
        // Parse date range para obtener checkin y checkout
        const regex = /(\d{4}[-/]\d{2}[-/]\d{2})\s*➜\s*(\d{4}[-/]\d{2}[-/]\d{2})/;
        const match = dateRange.match(regex);

        if (!match) {
          return { available: false, message: 'Fechas inválidas' };
        }

        const checkin = match[1];
        const checkout = match[2];

        // Para esta implementación básica, verificamos disponibilidad genérica
        // En producción, verificar por roomId específico
        try {
          const response = await fetch(`/api/availability?checkin=${checkin}&checkout=${checkout}&roomId=${roomId || 'double'}`);
          const data = await response.json();

          if (data.available) {
            return { available: true, message: 'Habitación disponible' };
          } else {
            return { available: false, message: 'Habitación no disponible para estas fechas' };
          }
        } catch (error) {
          console.error('Error checking availability:', error);
          return { available: true, message: 'No se pudo verificar disponibilidad, continuando...' };
        }
      }

      const btn = document.getElementById("btnSubmit") as HTMLButtonElement;
      btn?.addEventListener("click", async () => {
        if (!validateForm()) {
          return;
        }

        // Verificar disponibilidad antes de continuar
        const isGroupMode = !groupFields?.classList.contains("hidden");
        const dateRangeValue = isGroupMode
          ? (document.getElementById("dateRangeGroup") as HTMLInputElement)?.value
          : (document.getElementById("dateRange") as HTMLInputElement)?.value;
        if (dateRangeValue) {
          const availability = await checkAvailability(dateRangeValue);

          if (!availability.available) {
            window.showToast(availability.message, 'error');
            return;
          }
        }

        clearValidationErrors();
        if (!groupFields?.classList.contains("hidden") && dateRangeGroup) {
          dateRangeStandard.value = dateRangeGroup.value;
        }
        const originalButtonHTML = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = `<svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg"  viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Verificando disponibilidad...`;

        try {
          const formData = new FormData(form);
          const whatsappNumber = form.dataset.whatsapp;
          const isGroupMode = !groupFields?.classList.contains("hidden");

          const { data, error } = await actions.booking(formData);

          if (error) {
            console.error("Validation error:", error);
            if ("fields" in error && Array.isArray(error.fields)) {
              handleValidationErrors(error.fields);
            }
            return;
          }

          const { processing, bookingNumber } = data;
          const vehicleSwitchForSubmit = form.querySelector('[data-switch-name="vehicle"]') as HTMLButtonElement;
          const isVehicleChecked = vehicleSwitchForSubmit?.getAttribute("aria-checked") === "true";

          const distributionLabel =
            (document.getElementById("distributionType") as HTMLSelectElement)
              ?.options[
              (
                document.getElementById(
                  "distributionType",
                ) as HTMLSelectElement
              )?.selectedIndex
            ]?.text || formData.get("distributionType");

          const vehicleItems = Array.from(
            vehicleSection?.querySelectorAll(".vehicle-item") || [],
          ).map((item) => ({
            type: (
              item.querySelector(
                `select[name^="vehicleType"]`,
              ) as HTMLSelectElement
            )?.value,
            plate: (
              item.querySelector(
                `input[name^="vehiclePlate"]`,
              ) as HTMLInputElement
            )?.value,
          }));

          // Show booking summary modal before sending to WhatsApp
          showBookingSummary({
            processing,
            bookingNumber,
            isGroupMode,
            isVehicleChecked,
            vehicleItems,
            distributionLabel,
            groupAdults: formData.get("groupAdults"),
            groupTeens: formData.get("groupTeens"),
            groupKids: formData.get("groupKids"),
            groupInfants: formData.get("groupInfants"),
            groupNotes: formData.get("groupNotes"),
            breakfast: isGroupMode
              ? String(formData.get("breakfast") ?? "")
              : String(processing?.breakfast ?? ""),
            whatsappNumber,
          });

        } catch (err) {
          console.error("Error inesperado al enviar la reserva:", err);
          window.showToast(
            "Ocurrió un error inesperado. Por favor, inténtalo de nuevo.",
            "error",
          );
        } finally {
          btn.disabled = false;
          btn.innerHTML = originalButtonHTML;
        }
      });

      // Booking Summary Modal Functions
      function showBookingSummary(bookingData: any) {
        const modal = document.getElementById("booking-summary-modal");
        const closeBtn = document.getElementById("modal-close");
        const cancelBtn = document.getElementById("modal-cancel");
        const confirmBtn = document.getElementById("modal-confirm");
        const policiesCheckbox = document.getElementById("summary-policies-checkbox") as HTMLInputElement;

        if (!modal) return;

        // Fill summary data
        fillSummaryData(bookingData);

        // Show modal
        modal.classList.remove("hidden");
        setTimeout(() => {
          modal.classList.add("active");
        }, 10);

        if (policiesCheckbox) {
          policiesCheckbox.checked = false;
        }
        if (confirmBtn) {
          (confirmBtn as HTMLButtonElement).disabled = true;
        }

        // Enable confirm button when policies are accepted
        if (policiesCheckbox) {
          policiesCheckbox.onchange = function() {
            if (confirmBtn) {
              (confirmBtn as HTMLButtonElement).disabled = !this.checked;
            }
          };
        }

        // Close modal function
        const closeModal = () => {
          modal.classList.remove("active");
          setTimeout(() => {
            modal.classList.add("hidden");
          }, 300);
        };

        // Event listeners
        if (closeBtn) closeBtn.onclick = closeModal;
        if (cancelBtn) cancelBtn.onclick = closeModal;

        // Close on backdrop click
        modal.onclick = (e) => {
          const target = e.target as HTMLElement;
          if (target === modal || target.id === "modal-backdrop") {
            closeModal();
          }
        };

        // Confirm and send to WhatsApp
        if (confirmBtn) confirmBtn.onclick = () => {
          sendToWhatsApp(bookingData, bookingData.bookingNumber);
          closeModal();
        };

        // Close on escape key
        const handleEscape = (e: KeyboardEvent) => {
          if (e.key === "Escape") {
            closeModal();
            document.removeEventListener("keydown", handleEscape);
          }
        };
        document.addEventListener("keydown", handleEscape);
      }

      function fillSummaryData(bookingData: any) {
        const { processing, isGroupMode, isVehicleChecked, vehicleItems, distributionLabel } = bookingData;

        // Dates
        document.getElementById("summary-checkin")!.textContent = processing.checkin || "-";
        document.getElementById("summary-checkout")!.textContent = processing.checkout || "-";
        document.getElementById("summary-nights")!.textContent = `${processing.nights} ${lang === "es" ? "noches" : "nights"}`;

        // Guests
        document.getElementById("summary-adults")!.textContent = processing.adults || "-";
        document.getElementById("summary-children")!.textContent = processing.children || "0";
        document.getElementById("summary-rooms")!.textContent = processing.rooms || "1";
        document.getElementById("summary-breakfast")!.textContent = bookingData.breakfast === "true" ? (lang === "es" ? "Sí" : "Yes") : (lang === "es" ? "No" : "No");

        // Group info
        const groupSection = document.getElementById("summary-group-section");
        if (isGroupMode) {
          groupSection?.classList.remove("hidden");
          document.getElementById("summary-group-adults")!.textContent = bookingData.groupAdults || "-";
          document.getElementById("summary-group-teens")!.textContent = bookingData.groupTeens || "0";
          document.getElementById("summary-group-kids")!.textContent = bookingData.groupKids || "0";
          document.getElementById("summary-group-infants")!.textContent = bookingData.groupInfants || "0";
          document.getElementById("summary-distribution")!.textContent = distributionLabel || "-";
          
          const notesContainer = document.getElementById("summary-group-notes-container");
          const notesText = document.getElementById("summary-group-notes");
          if (bookingData.groupNotes && notesText) {
            notesContainer?.classList.remove("hidden");
            notesText.textContent = bookingData.groupNotes;
          } else {
            notesContainer?.classList.add("hidden");
          }
        } else {
          groupSection?.classList.add("hidden");
        }

        // Vehicle info
        const vehicleSection = document.getElementById("summary-vehicle-section");
        const vehicleList = document.getElementById("summary-vehicle-list");
        if (isVehicleChecked && vehicleItems?.length > 0) {
          vehicleSection?.classList.remove("hidden");
          vehicleList!.innerHTML = vehicleItems.map((v: any, i: number) => `
            <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
              <div class="flex items-center gap-3">
                <span class="text-xs font-bold text-gray-500 uppercase">${lang === "es" ? "Vehículo" : "Vehicle"} ${i + 1}</span>
                <span class="text-sm font-medium text-gray-900">${v.type || "-"}</span>
              </div>
              ${v.plate && v.plate !== "No especificada" ? `<span class="text-xs text-gray-600">${lang === "es" ? "Placa" : "Plate"}: ${v.plate}</span>` : ""}
            </div>
          `).join("");
        } else {
          vehicleSection?.classList.add("hidden");
        }

        // Total (placeholder - would need room price to calculate)
        document.getElementById("summary-total")!.textContent = lang === "es" ? "Consultar" : "Check Availability";
      }

      function sendToWhatsApp(bookingData: any, bookingNumber?: string) {
        const { processing, isGroupMode, isVehicleChecked, vehicleItems, whatsappNumber } = bookingData;

        const message = buildBookingMessage({
          isGroupMode,
          dateRangeRaw: "",
          groupAdults: bookingData.groupAdults,
          groupTeens: bookingData.groupTeens,
          groupKids: bookingData.groupKids,
          groupInfants: bookingData.groupInfants,
          distributionLabel: bookingData.distributionLabel,
          groupNotes: bookingData.groupNotes,
          processing: {
            checkin: processing.checkin,
            checkout: processing.checkout,
            nights: processing.nights,
            adults: processing.adults,
            children: processing.children,
            rooms: processing.rooms,
            breakfast: bookingData.breakfast,
          },
          isVehicleChecked,
          vehicleItems,
        });

        const encodedMessage = encodeURIComponent(message.trim());

        if (whatsappNumber) {
          window.open(
            `https://wa.me/${whatsappNumber}?text=${encodedMessage}`,
            "_blank",
          );
          
          // Redirigir a página de confirmación con datos
          const confirmationUrl = `/booking/confirmation?booking=${bookingNumber || "RES-XXXXXX"}&checkin=${processing.checkin}&checkout=${processing.checkout}&nights=${processing.nights}&adults=${processing.adults}&children=${processing.children}&rooms=${processing.rooms}&total=${processing.totalPrice || "0"}`;
          window.location.href = confirmationUrl;
          
          window.showToast(
            `Reserva #${bookingNumber || 'XXXXXX'} creada exitosamente`,
            "success",
          );
        } else {
          window.showToast(
            "No se pudo enviar el mensaje, el número de WhatsApp no está configurado.",
            "error",
          );
        }
      }
    });
  </script>

  <style>
    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button {
      opacity: 1;
    }
  </style>
</form>
