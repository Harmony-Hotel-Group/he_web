# ==================================================
#      CONFIGURACIÓN DE PRODUCCIÓN
# ==================================================
# Copia este archivo a .env y configura tus valores

# ==================================================
#      ENTORNO
# ==================================================
NODE_ENV=production
FORCE_HTTPS=true
SITE_URL=https://hotelensuenos.com

# ==================================================
#      SEGURIDAD
# ==================================================
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
CSRF_SECRET=

# ==================================================
#      ADMIN
# ==================================================
# Cambiar estas credenciales en producción
ADMIN_USERNAME=hoteladmin
ADMIN_PASSWORD_HASH=

# ==================================================
#      EMAIL (MAILGUN)
# ==================================================
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.hotelensuenos.com
SENDER_EMAIL=noreply@hotelensuenos.com
ADMIN_EMAIL=admin@hotelensuenos.com

# ==================================================
#      WHATSAPP
# ==================================================
WHATSAPP_NUMBER=593978888020
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_DESTINATION_PHONE=593978888020

# ==================================================
#      TELEGRAM (NOTIFICACIONES)
# ==================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ==================================================
#      ANALYTICS
# ==================================================
PUBLIC_MIXPANEL_TOKEN=

# ==================================================
#      API
# ==================================================
PUBLIC_API_BASE_URL=https://hotelensuenos.com
STATUS_CHECK_INTERVAL_MINUTES=5

# ==================================================
#      CACHE
# ==================================================
CACHE_PRIVATE_KEY=

# ==================================================
#      LOGGING
# ==================================================
LOG_ENABLED=true
LOG_LEVEL=info
LOG_CONTEXTS=*

# ==================================================
#      RATE LIMITING
# ==================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_WINDOW=60

# ==================================================
#      ERP (OPCIONAL)
# ==================================================
PUBLIC_ERP_BASE_URL=
PUBLIC_ERP_MODE=mock
PUBLIC_ERP_TIMEOUT_MS=5000
