---
import ImageResource from "@/components/molecules/media/ImageResource.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { api } from "@/services/api";
import type { SiteConfig } from "@/types/config";
import type { Room } from "@/types/rooms";
import { formatPrice } from "@/utils/currency";

// Determinar idioma basado en URL
const lang = Astro.url.pathname.startsWith("/en") ? "en" : "es";

// Multi-fetch de configuración y habitaciones
// Se hace cast del resultado para tener tipado fuerte en el destructuring
const { config, rooms } = (await api.multiFetch({
	config: { params: { lang } },
	rooms: { params: { lang } },
})) as { config: SiteConfig; rooms: Room[] | Error | null };

// Validación de seguridad para habitaciones
const safeRooms = Array.isArray(rooms) ? rooms : [];
---

<BaseLayout titleKey="nav.rooms" lang={lang} config={config}>
  <!-- Hero Section -->
  <section class="relative h-[50vh] min-h-[400px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gray-900/40 z-10"></div>
    <ImageResource
      src="src/assets/img/hotel/facade/sun.webp"
      alt="Luxury Rooms"
      loading="eager"
      classes="absolute inset-0 w-full h-full object-cover"
      wrapperClasses="absolute inset-0"
    />
    <div class="relative z-20 text-center px-4 max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif text-white font-bold mb-4 drop-shadow-lg tracking-wide">
        {lang === 'es' ? 'Nuestras Habitaciones' : 'Our Rooms'}
      </h1>
      <p class="text-lg md:text-xl text-gray-100 font-light max-w-2xl mx-auto drop-shadow-md">
        {lang === 'es' 
          ? 'Descubre el confort y la elegancia en cada rincón. Espacios diseñados para tu descanso absoluto.' 
          : 'Discover comfort and elegance in every corner. Spaces designed for your absolute rest.'}
      </p>
    </div>
  </section>

  <!-- Rooms List -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      {safeRooms.length > 0 ? (
        <>
          <!-- Filters -->
          <div class="mb-12 bg-white rounded-xl shadow-sm p-6 border border-gray-100">
            <div class="flex flex-col md:flex-row gap-6">
              <!-- Price Range -->
              <div class="flex-1">
                <label class="block text-sm font-semibold text-gray-700 mb-2">
                  {lang === 'es' ? 'Rango de Precio' : 'Price Range'}
                </label>
                <div class="flex items-center gap-4">
                  <input
                    type="range"
                    id="price-range"
                    min="25"
                    max="160"
                    step="5"
                    value="160"
                    class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-accent"
                  />
                  <span id="price-value" class="text-lg font-bold text-accent whitespace-nowrap">
                    $160
                  </span>
                </div>
              </div>
              
              <!-- Capacity -->
              <div class="flex-1">
                <label class="block text-sm font-semibold text-gray-700 mb-2">
                  {lang === 'es' ? 'Capacidad' : 'Capacity'}
                </label>
                <div class="flex flex-wrap gap-2">
                  <button
                    data-capacity="all"
                    class="capacity-filter px-4 py-2 text-sm font-semibold rounded-full bg-accent text-white transition-all"
                  >
                    {lang === 'es' ? 'Todas' : 'All'}
                  </button>
                  <button
                    data-capacity="2"
                    class="capacity-filter px-4 py-2 text-sm font-semibold rounded-full bg-gray-100 text-gray-700 hover:bg-accent hover:text-white transition-all"
                  >
                    1-2
                  </button>
                  <button
                    data-capacity="4"
                    class="capacity-filter px-4 py-2 text-sm font-semibold rounded-full bg-gray-100 text-gray-700 hover:bg-accent hover:text-white transition-all"
                  >
                    3-4
                  </button>
                  <button
                    data-capacity="6"
                    class="capacity-filter px-4 py-2 text-sm font-semibold rounded-full bg-gray-100 text-gray-700 hover:bg-accent hover:text-white transition-all"
                  >
                    5-6+
                  </button>
                </div>
              </div>
              
              <!-- Category -->
              <div class="flex-1">
                <label class="block text-sm font-semibold text-gray-700 mb-2">
                  {lang === 'es' ? 'Categoría' : 'Category'}
                </label>
                <div class="flex flex-wrap gap-2">
                  <button
                    data-category="all"
                    class="category-filter px-4 py-2 text-sm font-semibold rounded-full bg-accent text-white transition-all"
                  >
                    {lang === 'es' ? 'Todas' : 'All'}
                  </button>
                  <button
                    data-category="Estándar"
                    class="category-filter px-4 py-2 text-sm font-semibold rounded-full bg-gray-100 text-gray-700 hover:bg-accent hover:text-white transition-all"
                  >
                    {lang === 'es' ? 'Estándar' : 'Standard'}
                  </button>
                  <button
                    data-category="Familiar"
                    class="category-filter px-4 py-2 text-sm font-semibold rounded-full bg-gray-100 text-gray-700 hover:bg-accent hover:text-white transition-all"
                  >
                    {lang === 'es' ? 'Familiar' : 'Family'}
                  </button>
                  <button
                    data-category="Suite"
                    class="category-filter px-4 py-2 text-sm font-semibold rounded-full bg-gray-100 text-gray-700 hover:bg-accent hover:text-white transition-all"
                  >
                    Suite
                  </button>
                </div>
              </div>
            </div>
            
            <!-- Results count -->
            <div class="mt-4 pt-4 border-t border-gray-100">
              <p class="text-sm text-gray-600">
                <span id="results-count">{safeRooms.length}</span> 
                {lang === 'es' ? 'habitaciones encontradas' : 'rooms found'}
              </p>
            </div>
          </div>

          <!-- Rooms Grid -->
          <div class="rooms-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
            {safeRooms.map((room) => {
              const maxPersons = room.maxPersons || 2;
              const category = room.category?.[lang] || room.category?.es || '';
              return (
                <article
                  class="room-card group relative bg-white rounded-sm shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden flex flex-col h-full border border-gray-100"
                  data-price={room.pricePerNight}
                  data-capacity={maxPersons}
                  data-category={category}
                >
              <!-- Image -->
              <div class="relative overflow-hidden aspect-[4/3]">
                <ImageResource
                  src={room.images.find(img => img.frontpage)?.src || room.images[0]?.src}
                  alt={room.images[0]?.alt[lang] || room.name[lang]}
                  loading="lazy"
                  classes="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  wrapperClasses="w-full h-full"
                />
                 <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm px-4 py-1.5 text-primary font-serif font-bold text-lg shadow-sm">
                  {formatPrice(room.pricePerNight, room.currency, lang)} <span class="text-xs font-sans font-normal text-gray-500">/ {lang === 'es' ? 'noche' : 'night'}</span>
                </div>
              </div>

              <!-- Content -->
              <div class="p-6 flex flex-col flex-grow">
                <div class="mb-4">
                  <span class="text-xs font-bold tracking-widest text-accent uppercase">{room.type[lang]}</span>
                  <h3 class="text-2xl font-serif text-primary mt-2 mb-3 group-hover:text-accent transition-colors">
                    <a href={`/rooms/${room.id}`}>
                      {room.name[lang]}
                    </a>
                  </h3>
                  <p class="text-gray-600 line-clamp-3 text-sm leading-relaxed">
                    {room.description[lang]}
                  </p>
                </div>

                <!-- Amenities Preview -->
                <div class="mt-auto pt-6 border-t border-gray-100">
                  <div class="flex flex-wrap gap-2 mb-6">
                    {(room.amenities?.[lang] || []).slice(0, 3).map((amenity) => (
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                        {amenity}
                      </span>
                    ))}
                    {(room.amenities?.[lang] || []).length > 3 && (
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
                        +{(room.amenities?.[lang] || []).length - 3}
                      </span>
                    )}
                  </div>

                  <a 
                    href={`/rooms/${room.id}`}
                    class="block w-full text-center bg-primary text-white py-3 px-4 uppercase tracking-widest text-xs font-bold hover:bg-accent transition-colors duration-300"
                  >
                    {lang === 'es' ? 'Ver Detalles' : 'View Details'}
                  </a>
                </div>
              </div>
            </article>
              );
            })}
          </div>
          
          <!-- No results message -->
          <div id="no-results" class="hidden text-center py-12">
            <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-gray-600 text-lg">
              {lang === 'es' ? 'No se encontraron habitaciones con estos filtros' : 'No rooms found with these filters'}
            </p>
          </div>
        </>
      ) : (
        <div class="text-center py-20">
          <h2 class="text-2xl font-serif text-gray-600">
            {lang === 'es' ? 'No hay habitaciones disponibles en este momento.' : 'No rooms available at the moment.'}
          </h2>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .capacity-filter.active,
  .category-filter.active {
    background: rgb(217 119 6);
    color: white;
  }
  
  .room-card.hidden {
    display: none;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const priceRange = document.getElementById("price-range") as HTMLInputElement;
    const priceValue = document.getElementById("price-value");
    const capacityFilters = document.querySelectorAll(".capacity-filter");
    const categoryFilters = document.querySelectorAll(".category-filter");
    const roomCards = document.querySelectorAll(".room-card");
    const resultsCount = document.getElementById("results-count");
    const noResults = document.getElementById("no-results");

    let currentMaxPrice = 160;
    let currentCapacity = "all";
    let currentCategory = "all";

    function updateFilters() {
      let visibleCount = 0;

      roomCards.forEach(card => {
        const price = parseInt(card.getAttribute("data-price") || "0");
        const capacity = parseInt(card.getAttribute("data-capacity") || "0");
        const category = card.getAttribute("data-category") || "";

        // Check price
        const priceMatch = price <= currentMaxPrice;
        
        // Check capacity
        let capacityMatch = true;
        if (currentCapacity === "2") {
          capacityMatch = capacity <= 2;
        } else if (currentCapacity === "4") {
          capacityMatch = capacity >= 3 && capacity <= 4;
        } else if (currentCapacity === "6") {
          capacityMatch = capacity >= 5;
        }

        // Check category
        const categoryMatch = currentCategory === "all" || category === currentCategory;

        // Show/hide
        if (priceMatch && capacityMatch && categoryMatch) {
          card.classList.remove("hidden");
          visibleCount++;
        } else {
          card.classList.add("hidden");
        }
      });

      // Update count
      if (resultsCount) {
        resultsCount.textContent = visibleCount.toString();
      }

      // Show/hide no results message
      if (noResults) {
        if (visibleCount === 0) {
          noResults.classList.remove("hidden");
        } else {
          noResults.classList.add("hidden");
        }
      }
    }

    // Price range
    priceRange?.addEventListener("input", () => {
      currentMaxPrice = parseInt(priceRange.value);
      if (priceValue) {
        priceValue.textContent = `$${currentMaxPrice}`;
      }
      updateFilters();
    });

    // Capacity filters
    capacityFilters.forEach(filter => {
      filter.addEventListener("click", () => {
        const capacity = filter.getAttribute("data-capacity");
        
        capacityFilters.forEach(f => {
          f.classList.remove("active");
          f.classList.remove("bg-accent", "text-white");
          f.classList.add("bg-gray-100", "text-gray-700");
        });
        filter.classList.add("active");
        filter.classList.remove("bg-gray-100", "text-gray-700");
        filter.classList.add("bg-accent", "text-white");
        
        currentCapacity = capacity || "all";
        updateFilters();
      });
    });

    // Category filters
    categoryFilters.forEach(filter => {
      filter.addEventListener("click", () => {
        const category = filter.getAttribute("data-category");
        
        categoryFilters.forEach(f => {
          f.classList.remove("active");
          f.classList.remove("bg-accent", "text-white");
          f.classList.add("bg-gray-100", "text-gray-700");
        });
        filter.classList.add("active");
        filter.classList.remove("bg-gray-100", "text-gray-700");
        filter.classList.add("bg-accent", "text-white");
        
        currentCategory = category || "all";
        updateFilters();
      });
    });
  });
</script>
