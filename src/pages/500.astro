---
// pages/500.astro

import { Translations } from "@/i18n/translation.ts";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { api } from "@/services/api.ts";
import type { SiteConfig } from "@/types/config";

const lang = Astro.url.pathname.startsWith("/en") ? "en" : "es";
const t = Translations(lang);
const config = (await api.fetch("config", { params: { lang } })) as SiteConfig;

const texts = {
	es: {
		title: "Error del Servidor",
		code: "500",
		message:
			"Algo salió mal en nuestro servidor. Por favor, intenta de nuevo más tarde.",
		goHome: "Ir al Inicio",
		retry: "Intentar de Nuevo",
		contact: "Si el problema persiste, contáctanos",
	},
	en: {
		title: "Server Error",
		code: "500",
		message: "Something went wrong on our server. Please try again later.",
		goHome: "Go Home",
		retry: "Try Again",
		contact: "If the problem persists, contact us",
	},
};

const currentTexts = texts[lang as "es" | "en"] || texts.es;
---

<BaseLayout
    title="500 - Server Error"
    lang={lang}
    config={config}
    headerBgClass="text-gray-900"
>
    <!-- 500 Hero -->
    <section class="min-h-screen flex items-center justify-center bg-gradient-to-br from-red-600 via-red-700 to-red-900 py-20">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <!-- 500 Number -->
            <div class="mb-8">
                <span class="text-9xl font-bold text-white/20">{currentTexts.code}</span>
            </div>
            
            <!-- Icon -->
            <div class="inline-flex items-center justify-center w-24 h-24 bg-white/20 rounded-full mb-8 backdrop-blur-sm">
                <svg class="w-16 h-16 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
            </div>
            
            <!-- Content -->
            <h1 class="text-4xl md:text-5xl font-serif text-white font-bold mb-6">
                {currentTexts.title}
            </h1>
            <p class="text-xl text-white/90 mb-12 max-w-2xl mx-auto">
                {currentTexts.message}
            </p>
            
            <!-- Actions -->
            <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
                <a
                    href="/"
                    class="inline-flex items-center justify-center gap-2 bg-white text-red-600 font-bold py-4 px-8 rounded-xl text-lg hover:bg-white/90 transition-all transform hover:scale-105 shadow-xl"
                >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                    </svg>
                    {currentTexts.goHome}
                </a>
                <button
                    onclick="window.location.reload()"
                    class="inline-flex items-center justify-center gap-2 bg-transparent border-2 border-white text-white font-bold py-4 px-8 rounded-xl text-lg hover:bg-white/10 transition-all"
                >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                    </svg>
                    {currentTexts.retry}
                </button>
            </div>
            
            <!-- Contact Info -->
            <div class="text-white/80">
                <p class="text-lg mb-4">{currentTexts.contact}</p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center text-sm">
                    <a href="tel:+593978888020" class="hover:text-white transition-colors">
                        📞 +593 97 888 8020
                    </a>
                    <a href="mailto:reservas@hotelensuenos.com" class="hover:text-white transition-colors">
                        ✉️ reservas@hotelensuenos.com
                    </a>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
