---
// src/components/ui/ImageResource.astro
/**
 * Componente especializado para imágenes
 * Incluye lazy loading, srcset, y fallback automático
 * Usa el componente Imagen.astro para optimización
 */

import type { ImageMetadata } from "astro";
import Imagen from "@/components/atoms/image/Imagen.astro";
import { validateResource } from "@/utils/visual-resource-utils.ts";

interface Props {
	src: string | ImageMetadata;
	alt?: string;
	width?: number;
	height?: number;
	loading?: "lazy" | "eager";
	classes?: string;
	srcset?: string;
	sizes?: string;
	decoding?: "async" | "sync" | "auto";
	wrapperClasses?: string;
}

const {
	src,
	alt = "",
	width = 600,
	height = 400,
	loading = "lazy",
	classes = "",
	decoding = "async",
	wrapperClasses = "",
} = Astro.props;

function getInlinePlaceholder(
	w: number,
	h: number,
	text: string,
): string {
	const safeW = Number.isFinite(w) && w > 0 ? Math.round(w) : 600;
	const safeH = Number.isFinite(h) && h > 0 ? Math.round(h) : 400;
	const safeText = (text || "Imagen no disponible").slice(0, 40);
	const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${safeW}" height="${safeH}" viewBox="0 0 ${safeW} ${safeH}"><rect width="100%" height="100%" fill="#f0f0f0"/><text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="#9ca3af" font-family="Arial, sans-serif" font-size="16">${safeText}</text></svg>`;
	return `data:image/svg+xml;charset=utf-8,${encodeURIComponent(svg)}`;
}

const placeholderSrc = getInlinePlaceholder(
	width,
	height,
	alt || "Imagen no disponible",
);

// Validar si src es string
let finalSrc = src;
if (typeof src === "string") {
	const validation = await validateResource(src, "image");
	if (validation.isValid && validation.finalSrc) {
		finalSrc = validation.finalSrc;
	} else {
		finalSrc = placeholderSrc;
	}
}

// Generar ID único para el skeleton
const imageId = `img-${String(Math.random().toString(36)).substring(2, 9)}`;
---

<div class={`image-resource-wrapper ${wrapperClasses}`} data-image-id={imageId}>
    <Imagen
        id={imageId}
        src={finalSrc}
        alt={alt}
        width={width}
        height={height}
        loading={loading}
        decoding={decoding}
        data-placeholder={placeholderSrc}
        class={`image-resource ${classes}`}
    />

    <!-- Skeleton overlay (se oculta cuando carga) -->
    <div class="image-skeleton" data-skeleton-for={imageId}>
        <div class="skeleton-shimmer"></div>
    </div>
</div>

<style>
    .image-resource-wrapper {
        position: relative;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #f5f5f5;
    }

    .image-resource {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        opacity: 1;
        transition: opacity 0.3s ease;
        position: relative;
        z-index: 1;
    }

    /* Skeleton loading effect */
    .image-skeleton {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #f0f0f0;
        overflow: hidden;
        pointer-events: none;
        transition: opacity 0.3s ease;
        z-index: 2;
    }

    .image-skeleton.hidden {
        opacity: 0;
        pointer-events: none;
    }

    .skeleton-shimmer {
        width: 100%;
        height: 100%;
        background: linear-gradient(
            90deg,
            #f0f0f0 0%,
            #e0e0e0 20%,
            #f0f0f0 40%,
            #f0f0f0 100%
        );
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite linear;
    }

    @keyframes shimmer {
        0% {
            background-position: -200% 0;
        }
        100% {
            background-position: 200% 0;
        }
    }

    /* Estado de error */
    .image-resource-wrapper.error .image-skeleton {
        background: #fee;
        border: 2px dashed #fcc;
    }

    .image-resource-wrapper.error .skeleton-shimmer {
        display: flex;
        align-items: center;
        justify-content: center;
        color: #c33;
        font-size: 0.875rem;
        animation: none;
        background: transparent;
    }

    .image-resource-wrapper.error .skeleton-shimmer::before {
        content: "⚠️ Imagen no disponible";
    }
</style>

<script>
    /**
     * Manejo de carga de imágenes
     * Detecta cuando la imagen carga y quita el skeleton
     */

    class ImageResourceManager {
        constructor(loggerInstance) {
            this.images = new Map();
            this.skeletons = new Map();
            this.log = loggerInstance;
            if (document.readyState === "loading") {
                document.addEventListener("DOMContentLoaded", () => {
                    this.initImages();
                });
            } else {
                this.initImages();
            }
        }

        initImages() {
            const wrappers = document.querySelectorAll("[data-image-id]");

            wrappers.forEach((wrapper) => {
                const imageId = wrapper.getAttribute("data-image-id");
                if (!imageId) return;

                const img = wrapper.querySelector(`#${imageId}`);
                const skeleton = wrapper.querySelector(
                    `[data-skeleton-for="${imageId}"]`,
                );

                if (!img) return;

                this.images.set(imageId, img);
                if (skeleton) {
                    this.skeletons.set(imageId, skeleton);
                }

                const placeholder = img.dataset.placeholder;
                // Si la imagen ya está cargada (cached)
                if (img.complete && img.naturalHeight !== 0) {
                    this.handleImageLoad(imageId, img, skeleton);
                } else if (placeholder && img.src === placeholder) {
                    this.handleImageLoad(imageId, img, skeleton);
                } else {
                    // Event listeners para carga
                    img.addEventListener("load", () => {
                        this.handleImageLoad(imageId, img, skeleton);
                    });

                    img.addEventListener("error", () => {
                        this.handleImageError(imageId, wrapper, skeleton, img);
                    });
                }

                // Fallback: evitar skeleton infinito si por alguna razón no se disparan eventos
                setTimeout(() => {
                    if (skeleton && !skeleton.classList.contains("hidden")) {
                        if (img.complete || img.naturalHeight !== 0 || img.currentSrc) {
                            this.handleImageLoad(imageId, img, skeleton);
                        }
                    }
                }, 1500);
            });

            this.log.info(`Initialized ${this.images.size} image(s)`);
        }

        handleImageLoad(imageId, img, skeleton) {
            // Ocultar skeleton
            if (skeleton) {
                skeleton.classList.add("hidden");
            }

            // Mostrar imagen con fade in
            img.classList.add("loaded");

            this.log.info(`Image loaded: ${imageId}`);
        }

        handleImageError(imageId, wrapper, skeleton, img) {
            this.log.error(`Failed to load image: ${imageId}`);

            // Marcar wrapper como error
            wrapper.classList.add("error");

            // Mantener skeleton visible pero cambiar estilo
            if (skeleton) {
                skeleton.classList.remove("hidden");
            }

            const placeholder = img.dataset.placeholder;
            if (placeholder && img.src !== placeholder) {
                img.src = placeholder;
                img.addEventListener(
                    "load",
                    () => this.handleImageLoad(imageId, img, skeleton),
                    { once: true },
                );
            }
        }

        getImageCount() {
            return this.images.size;
        }

        getLoadedCount() {
            let count = 0;
            this.images.forEach((img) => {
                if (img.classList.contains("loaded")) {
                    count++;
                }
            });
            return count;
        }
    }

    // Inicialización sin dependencias para evitar fallos por imports en scripts inline
    (() => {
        const log = {
            info: (...args: unknown[]) => console.log("[ImageResource]", ...args),
            warn: (...args: unknown[]) => console.warn("[ImageResource]", ...args),
            error: (...args: unknown[]) => console.error("[ImageResource]", ...args),
        };
        new ImageResourceManager(log);
    })();
</script>
