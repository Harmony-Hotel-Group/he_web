---
//pages/tours/index.astro

import ImageResource from "@/components/molecules/media/ImageResource.astro";
import { Translations } from "@/i18n/translation.ts";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { api } from "@/services/api.ts";
import { logger } from "@/services/logger.ts";
import type { SiteConfig } from "@/types/config";
import type { Tour } from "@/types/tours";
import { formatPrice } from "@/utils/currency";

interface Props {
	lang: string;
}

const { lang = "es" } = Astro.props;

const log = logger("tours");
log.info(`Rendering tours page with language: ${lang}`);

const config = (await api.fetch("config", { params: { lang } })) as SiteConfig;
const tours = (await api.fetch("tours", { params: { lang } })) as Tour[] | null;
const safeTours = Array.isArray(tours) ? tours : [];

const t = Translations(lang);
---

<BaseLayout titleKey="nav.tours" lang={lang} config={config}>
	<section class="bg-gray-100/90 backdrop-blur border-b border-gray-200">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-[6.5rem] pb-10">
			<h1 class="text-3xl md:text-4xl font-serif text-primary font-bold mb-2">
				{t("nav.tours")}
			</h1>
			<p class="text-gray-600 max-w-2xl">
				{lang === "es"
					? "Descubre las mejores experiencias en Cuenca y sus alrededores."
					: "Discover the best experiences in Cuenca and surroundings."}
			</p>
		</div>
	</section>

	<section class="py-16 md:py-20 bg-white">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			{safeTours.length === 0 ? (
				<div class="text-center py-20">
					<p class="text-gray-500 text-lg">
						{lang === "es"
							? "Próximamente nuevos tours disponibles."
							: "New tours coming soon."}
					</p>
				</div>
			) : (
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					{safeTours.map((tour) => (
						<a
							href={`/tours/${tour.id}`}
							class="group block bg-white border border-gray-200 rounded-lg overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-300"
						>
							{tour.images?.[0] && (
								<div class="aspect-video overflow-hidden">
									<ImageResource
										src={tour.images[0]}
										alt={tour.name[lang]}
										loading="lazy"
										classes="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
										wrapperClasses="w-full h-full"
									/>
								</div>
							)}
							<div class="p-6">
								<h3 class="text-xl font-serif text-primary font-semibold mb-2">
									{tour.name[lang]}
								</h3>
								<p class="text-gray-600 text-sm mb-4 line-clamp-2">
									{tour.description[lang]}
								</p>
								<div class="flex items-center justify-between">
									<span class="text-accent font-bold">
										{formatPrice(tour.price, tour.currency, lang)}
									</span>
									<span class="text-sm text-gray-400">
										{tour.duration}
									</span>
								</div>
							</div>
						</a>
					))}
				</div>
			)}
		</div>
	</section>
</BaseLayout>
