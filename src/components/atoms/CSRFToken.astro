---
// src/components/atoms/CSRFToken.astro
/**
 * Componente para generar input oculto con token CSRF
 */

import { generateCSRFToken, getSessionHash } from "@/utils/csrf";

const sessionId = await getSessionHash(Astro.request);
const csrfToken = await generateCSRFToken(sessionId);
---

<input 
    type="hidden" 
    name="_csrf" 
    value={csrfToken} 
    data-csrf-token
/>
