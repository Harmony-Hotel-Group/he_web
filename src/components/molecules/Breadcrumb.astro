---
// src/components/molecules/Breadcrumb.astro

interface BreadcrumbItem {
	label: string;
	href?: string;
}

interface Props {
	items: BreadcrumbItem[];
	lang?: string;
}

const { items, lang = "es" } = Astro.props;
---

<nav class="breadcrumb" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-sm text-gray-600 flex-wrap">
        <!-- Home -->
        <li>
            <a
                href="/"
                class="hover:text-accent transition-colors"
                aria-label="Home"
            >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
            </a>
        </li>
        
        <!-- Separators and items -->
        {items.map((item, index) => (
            <>
                <li class="text-gray-400">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                    </svg>
                </li>
                <li>
                    {item.href ? (
                        <a
                            href={item.href}
                            class="hover:text-accent transition-colors {index === items.length - 1 ? 'text-primary font-semibold' : ''}"
                        >
                            {item.label}
                        </a>
                    ) : (
                        <span class="text-primary font-semibold" aria-current="page">
                            {item.label}
                        </span>
                    )}
                </li>
            </>
        ))}
    </ol>
</nav>

<style>
    .breadcrumb ol {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    
    .breadcrumb a {
        text-decoration: none;
    }
    
    .breadcrumb li:last-child a {
        pointer-events: none;
    }
</style>
