---
//pages/cancellation.astro

// export const prerender = false;

import { Translations } from "@/i18n/translation.ts";
import { logger } from "@/services/logger.ts";

interface Props {
	lang: string;
}

const { lang = "es" } = Astro.props;

const log = logger("cancellation");

import UnderConstructionPage from "@/components/pages/UnderConstructionPage.astro";

const t = Translations(lang);
log.info(`Rendering cancellation page with language: ${lang}`);
---

<UnderConstructionPage
        titleHead={t("nav.cancellation")}
        title={t("underConstruction.cancellation.title")}
        message={t("underConstruction.cancellation.message")}
        btnBackLabel={t("underConstruction.back")}
        lang={lang}
/>
