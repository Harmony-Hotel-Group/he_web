---
// pages/404.astro

import { Translations } from "@/i18n/translation.ts";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { api } from "@/services/api.ts";
import type { SiteConfig } from "@/types/config";

const lang = Astro.url.pathname.startsWith("/en") ? "en" : "es";
const t = Translations(lang);
const config = (await api.fetch("config", { params: { lang } })) as SiteConfig;

const texts = {
	es: {
		title: "Página No Encontrada",
		code: "404",
		message: "Lo sentimos, la página que buscas no existe o ha sido movida.",
		goHome: "Ir al Inicio",
		contact: "¿Necesitas ayuda?",
		contactText: "Contáctanos y te ayudaremos a encontrar lo que buscas",
	},
	en: {
		title: "Page Not Found",
		code: "404",
		message:
			"Sorry, the page you're looking for doesn't exist or has been moved.",
		goHome: "Go Home",
		contact: "Need Help?",
		contactText: "Contact us and we'll help you find what you're looking for",
	},
};

const currentTexts = texts[lang as "es" | "en"] || texts.es;
---

<BaseLayout
    title="404 - Not Found"
    lang={lang}
    config={config}
    headerBgClass="text-gray-900"
>
    <!-- 404 Hero -->
    <section class="min-h-screen flex items-center justify-center bg-gradient-to-br from-primary via-primary/95 to-accent/90 py-20">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <!-- 404 Number -->
            <div class="mb-8">
                <span class="text-9xl font-bold text-white/20">{currentTexts.code}</span>
            </div>
            
            <!-- Icon -->
            <div class="inline-flex items-center justify-center w-24 h-24 bg-white/20 rounded-full mb-8 backdrop-blur-sm">
                <svg class="w-16 h-16 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            
            <!-- Content -->
            <h1 class="text-4xl md:text-5xl font-serif text-white font-bold mb-6">
                {currentTexts.title}
            </h1>
            <p class="text-xl text-white/90 mb-12 max-w-2xl mx-auto">
                {currentTexts.message}
            </p>
            
            <!-- Actions -->
            <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
                <a
                    href="/"
                    class="inline-flex items-center justify-center gap-2 bg-white text-primary font-bold py-4 px-8 rounded-xl text-lg hover:bg-white/90 transition-all transform hover:scale-105 shadow-xl"
                >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                    </svg>
                    {currentTexts.goHome}
                </a>
                <a
                    href="/contact"
                    class="inline-flex items-center justify-center gap-2 bg-transparent border-2 border-white text-white font-bold py-4 px-8 rounded-xl text-lg hover:bg-white/10 transition-all"
                >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                    {currentTexts.contact}
                </a>
            </div>
            
            <!-- Contact Info -->
            <div class="text-white/80">
                <p class="text-lg mb-4">{currentTexts.contactText}</p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center text-sm">
                    <a href="tel:+593978888020" class="hover:text-white transition-colors">
                        📞 +593 97 888 8020
                    </a>
                    <a href="mailto:reservas@hotelensuenos.com" class="hover:text-white transition-colors">
                        ✉️ reservas@hotelensuenos.com
                    </a>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
