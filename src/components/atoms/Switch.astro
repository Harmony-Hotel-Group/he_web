---
/**
 * src/components/atoms/Switch.astro
 * Componente atómico para un switch accesible y sin dependencias externas.
 */
interface Props {
	id?: string;
	name: string;
	checked?: boolean;
	disabled?: boolean;
	classes?: string;
}

const {
	id,
	name,
	checked = false,
	disabled = false,
	classes = "",
} = Astro.props;

const switchId = id || `switch-${name}-${Math.random().toString(36).slice(2, 9)}`;
---

<div class:list={["relative inline-block", classes]} data-switch-root={switchId}>
    <button
            id={switchId}
            type="button"
            role="switch"
            aria-checked={checked}
            data-switch-name={name}
            class:list={[
                "relative inline-flex items-center h-4 w-9 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out",
                "focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2",
                checked ? "bg-accent" : "bg-gray-200",
                disabled ? "opacity-50 cursor-not-allowed" : "",
            ]}
            disabled={disabled}
            tabindex="0"
    >
    <span
            aria-hidden="true"
            class:list={[
                "pointer-events-none inline-block h-3 w-3 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out",
                checked ? "translate-x-5" : "translate-x-0",
            ]}
    ></span>
    </button>

    <input type="hidden" name={name} value={checked.toString()}/>

    <script is:inline define:vars={{ switchId }}>
        (() => {
            console.log(`[Switch:${switchId}] Initializing script`);
            document.addEventListener("astro:page-load", () => {
                console.log(`[Switch:${switchId}] Page loaded, finding elements`);
                const root = document.querySelector(`[data-switch-root="${switchId}"]`);
                if (!root) {
                    console.error(`[Switch:${switchId}] Root not found`);
                    return;
                }
                console.log(`[Switch:${switchId}] Root found`);

                const button = root.querySelector('button[role="switch"]');
                const input = root.querySelector('input[type="hidden"]');
                const handle = button?.querySelector('span[aria-hidden="true"]');
                if (!button || !input || !handle) {
                    console.error(`[Switch:${switchId}] Elements not found`);
                    return;
                }
                console.log(`[Switch:${switchId}] Elements found, switchName: ${button.dataset.switchName}`);

                const switchName = button.dataset.switchName;

                const toggle = () => {
                    if (button.disabled) return;
                    const isChecked = button.getAttribute("aria-checked") === "true";
                    const newState = !isChecked;
                    console.log(`[Switch:${switchId}] Toggling from ${isChecked} to ${newState}`);
                    button.setAttribute("aria-checked", String(newState));
                    input.value = String(newState);

                    button.classList.toggle("bg-accent", newState);
                    button.classList.toggle("bg-gray-200", !newState);
                    handle.classList.toggle("translate-x-5", newState);
                    handle.classList.toggle("translate-x-0", !newState);

                    const event = new CustomEvent('switch:change', {
                        bubbles: true,
                        composed: true,
                        detail: { 
                            name: switchName, 
                            checked: newState,
                            element: button
                        }
                    });
                    console.log(`[Switch:${switchId}] Dispatching event:`, event.detail);
                    button.dispatchEvent(event);
                };

                button.addEventListener("click", toggle);
                button.addEventListener("keydown", (e) => {
                    if (e.key === " " || e.key === "Enter") {
                        e.preventDefault();
                        toggle();
                    }
                });
            });
        })();
    </script>
</div>
