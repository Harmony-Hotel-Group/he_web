---
// pages/contact.astro

import BaseLayout from "@/layouts/BaseLayout.astro";
import { Translations } from "@/i18n/translation.ts";
import { api } from "@/services/api.ts";
import type { SiteConfig } from "@/types/config";

const lang = Astro.url.pathname.startsWith("/en") ? "en" : "es";
const t = Translations(lang);

const config = (await api.fetch("config", { params: { lang } })) as SiteConfig;
---

<BaseLayout
	titleKey="nav.contact"
	lang={lang}
	config={config}
	headerBgClass="text-gray-900"
>
	<!-- Hero Section -->
	<section class="relative bg-gradient-to-br from-primary via-primary/95 to-accent/90">
		<div class="absolute inset-0 bg-black/20"></div>
		<div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
			<div class="text-center">
				<h1 class="text-4xl md:text-5xl lg:text-6xl font-serif text-white font-bold mb-4">
					{t("contact.title")}
				</h1>
				<p class="text-lg md:text-xl text-white/90 max-w-2xl mx-auto">
					{t("contact.subtitle")}
				</p>
			</div>
		</div>
	</section>

	<!-- Main Content -->
	<section class="py-16 md:py-24 bg-gray-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
				<!-- Left Column: Contact Form -->
				<div>
					<h2 class="text-2xl md:text-3xl font-serif text-primary font-bold mb-6">
						{t("contact.form.title")}
					</h2>

					<form id="contact-form" class="space-y-6">
						<!-- Name -->
						<div>
							<label
								for="name"
								class="block text-sm font-semibold text-gray-700 mb-2"
							>
								{t("contact.form.name.label")}
								<span class="text-red-500">*</span>
							</label>
							<input
								type="text"
								id="name"
								name="name"
								required
								placeholder={t("contact.form.name.placeholder")}
								class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent transition-all bg-white text-gray-900 placeholder-gray-400"
							/>
							<p id="error-name" class="hidden text-red-600 text-sm mt-1">
								{t("contact.form.name.error")}
							</p>
						</div>

						<!-- Email -->
						<div>
							<label
								for="email"
								class="block text-sm font-semibold text-gray-700 mb-2"
							>
								{t("contact.form.email.label")}
								<span class="text-red-500">*</span>
							</label>
							<input
								type="email"
								id="email"
								name="email"
								required
								placeholder={t("contact.form.email.placeholder")}
								class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent transition-all bg-white text-gray-900 placeholder-gray-400"
							/>
							<p id="error-email" class="hidden text-red-600 text-sm mt-1">
								{t("contact.form.email.error")}
							</p>
						</div>

						<!-- Phone -->
						<div>
							<label
								for="phone"
								class="block text-sm font-semibold text-gray-700 mb-2"
							>
								{t("contact.form.phone.label")}
							</label>
							<input
								type="tel"
								id="phone"
								name="phone"
								placeholder={t("contact.form.phone.placeholder")}
								class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent transition-all bg-white text-gray-900 placeholder-gray-400"
							/>
							<p id="error-phone" class="hidden text-red-600 text-sm mt-1">
								{t("contact.form.phone.error")}
							</p>
						</div>

						<!-- Subject -->
						<div>
							<label
								for="subject"
								class="block text-sm font-semibold text-gray-700 mb-2"
							>
								{t("contact.form.subject.label")}
								<span class="text-red-500">*</span>
							</label>
							<input
								type="text"
								id="subject"
								name="subject"
								required
								placeholder={t("contact.form.subject.placeholder")}
								class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent transition-all bg-white text-gray-900 placeholder-gray-400"
							/>
							<p id="error-subject" class="hidden text-red-600 text-sm mt-1">
								{t("contact.form.subject.error")}
							</p>
						</div>

						<!-- Message -->
						<div>
							<label
								for="message"
								class="block text-sm font-semibold text-gray-700 mb-2"
							>
								{t("contact.form.message.label")}
								<span class="text-red-500">*</span>
							</label>
							<textarea
								id="message"
								name="message"
								required
								rows={5}
								placeholder={t("contact.form.message.placeholder")}
								class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent transition-all bg-white text-gray-900 placeholder-gray-400 resize-none"
							></textarea>
							<p id="error-message" class="hidden text-red-600 text-sm mt-1">
								{t("contact.form.message.error")}
							</p>
						</div>

						<!-- Submit Button -->
						<button
							type="submit"
							id="submit-btn"
							class="w-full bg-accent text-white font-bold py-4 px-6 rounded-lg hover:bg-accent/90 transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 flex items-center justify-center gap-2"
						>
							<svg
								class="w-5 h-5"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"
								/>
							</svg>
							<span>{t("contact.form.submit")}</span>
						</button>

						<!-- Success/Error Messages -->
						<div
							id="form-success"
							class="hidden bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg"
						>
							{t("contact.form.success")}
						</div>
						<div
							id="form-error"
							class="hidden bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg"
						>
							{t("contact.form.error")}
						</div>
					</form>
				</div>

				<!-- Right Column: Contact Info + Map -->
				<div class="space-y-8">
					<!-- Contact Information Cards -->
					<div class="space-y-4">
						<h3 class="text-xl font-serif text-primary font-bold mb-4">
							{t("contact.info.title")}
						</h3>

						<!-- Address -->
						<a
							href={config?.contactInfo?.linkMap}
							target="_blank"
							rel="noopener noreferrer"
							class="flex items-start gap-4 p-4 bg-white border border-gray-200 rounded-lg hover:border-accent hover:shadow-md transition-all group"
						>
							<div class="p-3 bg-accent/10 rounded-lg group-hover:bg-accent/20 transition-colors">
								<svg
									class="w-6 h-6 text-accent"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
									/>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
									/>
								</svg>
							</div>
							<div>
								<p class="font-semibold text-gray-900">
									{t("contact.info.address")}
								</p>
								<p class="text-gray-600 text-sm mt-1">
									{config?.contactInfo?.address}
								</p>
								<p class="text-accent text-sm mt-2 font-medium">
									{t("contact.map.directions")} →
								</p>
							</div>
						</a>

						<!-- Phone -->
						<a
							href={`tel:${config?.contactInfo?.whatsapp}`}
							class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-lg hover:border-accent hover:shadow-md transition-all group"
						>
							<div class="p-3 bg-accent/10 rounded-lg group-hover:bg-accent/20 transition-colors">
								<svg
									class="w-6 h-6 text-accent"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
									/>
								</svg>
							</div>
							<div>
								<p class="font-semibold text-gray-900">
									{t("contact.info.phone")}
								</p>
								<p class="text-gray-600 text-sm mt-1">
									{config?.contactInfo?.whatsapp}
								</p>
							</div>
						</a>

						<!-- Email -->
						<a
							href={`mailto:${config?.contactInfo?.email}`}
							class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-lg hover:border-accent hover:shadow-md transition-all group"
						>
							<div class="p-3 bg-accent/10 rounded-lg group-hover:bg-accent/20 transition-colors">
								<svg
									class="w-6 h-6 text-accent"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
									/>
								</svg>
							</div>
							<div>
								<p class="font-semibold text-gray-900">
									{t("contact.info.email")}
								</p>
								<p class="text-gray-600 text-sm mt-1">
									{config?.contactInfo?.email}
								</p>
							</div>
						</a>

						<!-- WhatsApp -->
						<a
							href={`https://wa.me/${config?.contactInfo?.whatsapp?.replace('+', '')}`}
							target="_blank"
							rel="noopener noreferrer"
							class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-lg hover:border-accent hover:shadow-md transition-all group"
						>
							<div class="p-3 bg-accent/10 rounded-lg group-hover:bg-accent/20 transition-colors">
								<svg
									class="w-6 h-6 text-accent"
									fill="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
									/>
								</svg>
							</div>
							<div>
								<p class="font-semibold text-gray-900">
									{t("contact.info.whatsapp")}
								</p>
								<p class="text-gray-600 text-sm mt-1">
									{config?.contactInfo?.whatsapp}
								</p>
							</div>
						</a>
					</div>

					<!-- Office Hours -->
					<div class="bg-white border border-gray-200 rounded-lg p-6">
						<h4 class="text-lg font-serif text-primary font-bold mb-4">
							{t("contact.info.hours.title")}
						</h4>
						<div class="space-y-3">
							<div class="flex justify-between items-center py-2 border-b border-gray-100">
								<span class="text-gray-600">
									{t("contact.info.hours.reception")}
								</span>
								<span class="font-semibold text-gray-900">
									{t("contact.info.hours.247")}
								</span>
							</div>
							<div class="flex justify-between items-center py-2 border-b border-gray-100">
								<span class="text-gray-600">
									{t("contact.info.hours.reservations")}
								</span>
								<span class="font-semibold text-gray-900">
									{t("contact.info.hours.247")}
								</span>
							</div>
							<div class="flex justify-between items-center py-2">
								<span class="text-gray-600">
									{t("contact.info.hours.support")}
								</span>
								<span class="font-semibold text-gray-900">
									{t("contact.info.hours.247")}
								</span>
							</div>
						</div>
					</div>

					<!-- Google Maps Embed -->
					<div>
						<h4 class="text-lg font-serif text-primary font-bold mb-4">
							{t("contact.map.title")}
						</h4>
						<div class="relative aspect-video rounded-lg overflow-hidden border border-gray-200 shadow-lg">
							<iframe
								src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3982.408042249653!2d-78.9995!3d-2.8976!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x91ca30b0a5f5b5b5%3A0x1234567890abcdef!2sGran%20Colombia%20182%20y%20Manuel%20Vega%2C%20Cuenca%2C%20Ecuador!5e0!3m2!1ses!2sec!4v1234567890123!5m2!1ses!2sec"
								width="100%"
								height="100%"
								style="border:0"
								allowfullscreen=""
								loading="lazy"
								referrerpolicy="no-referrer-when-downgrade"
								class="absolute inset-0 w-full h-full"
								title="Ubicación de Hotel Ensueños"
							></iframe>
						</div>
					</div>
				</div>
			</div>

			<!-- FAQ Section -->
			<div class="mt-16 lg:mt-24">
				<h2 class="text-2xl md:text-3xl font-serif text-primary font-bold text-center mb-8">
					{t("contact.faq.title")}
				</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
					<!-- FAQ Item 1 -->
					<div class="bg-white border border-gray-200 rounded-lg p-6">
						<div class="flex items-start gap-3">
							<div class="p-2 bg-accent/10 rounded-lg shrink-0">
								<svg
									class="w-5 h-5 text-accent"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
									/>
								</svg>
							</div>
							<div>
								<h5 class="font-semibold text-gray-900 mb-2">
									{t("contact.faq.q1")}
								</h5>
								<p class="text-gray-600 text-sm">
									{t("contact.faq.a1")}
								</p>
							</div>
						</div>
					</div>

					<!-- FAQ Item 2 -->
					<div class="bg-white border border-gray-200 rounded-lg p-6">
						<div class="flex items-start gap-3">
							<div class="p-2 bg-accent/10 rounded-lg shrink-0">
								<svg
									class="w-5 h-5 text-accent"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
									/>
								</svg>
							</div>
							<div>
								<h5 class="font-semibold text-gray-900 mb-2">
									{t("contact.faq.q2")}
								</h5>
								<p class="text-gray-600 text-sm">
									{t("contact.faq.a2")}
								</p>
							</div>
						</div>
					</div>

					<!-- FAQ Item 3 -->
					<div class="bg-white border border-gray-200 rounded-lg p-6">
						<div class="flex items-start gap-3">
							<div class="p-2 bg-accent/10 rounded-lg shrink-0">
								<svg
									class="w-5 h-5 text-accent"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
									/>
								</svg>
							</div>
							<div>
								<h5 class="font-semibold text-gray-900 mb-2">
									{t("contact.faq.q3")}
								</h5>
								<p class="text-gray-600 text-sm">
									{t("contact.faq.a3")}
								</p>
							</div>
						</div>
					</div>

					<!-- FAQ Item 4 -->
					<div class="bg-white border border-gray-200 rounded-lg p-6">
						<div class="flex items-start gap-3">
							<div class="p-2 bg-accent/10 rounded-lg shrink-0">
								<svg
									class="w-5 h-5 text-accent"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"
									/>
								</svg>
							</div>
							<div>
								<h5 class="font-semibold text-gray-900 mb-2">
									{t("contact.faq.q4")}
								</h5>
								<p class="text-gray-600 text-sm">
									{t("contact.faq.a4")}
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<script>
		import { actions } from "astro:actions";

		document.addEventListener("DOMContentLoaded", () => {
			const form = document.getElementById("contact-form") as HTMLFormElement;
			const submitBtn = document.getElementById("submit-btn");
			const successMsg = document.getElementById("form-success");
			const errorMsg = document.getElementById("form-error");

			if (!form) return;

			// Detect language from URL
			const lang = window.location.pathname.startsWith("/en") ? "en" : "es";

			function clearErrors() {
				form.querySelectorAll('[id^="error-"]').forEach((el) => {
					el.classList.add("hidden");
				});
				form.querySelectorAll("input, textarea").forEach((el) => {
					el.classList.remove("border-red-500");
				});
			}

			function showError(field: string) {
				const errorEl = document.getElementById(`error-${field}`);
				const inputEl = form.querySelector(`[name="${field}"]`);
				if (errorEl) errorEl.classList.remove("hidden");
				if (inputEl) inputEl.classList.add("border-red-500");
			}

			function validateForm(): boolean {
				clearErrors();
				let isValid = true;

				const name = (form.querySelector("[name='name']") as HTMLInputElement)?.value.trim();
				const email = (form.querySelector("[name='email']") as HTMLInputElement)?.value.trim();
				const subject = (form.querySelector("[name='subject']") as HTMLInputElement)?.value.trim();
				const message = (form.querySelector("[name='message']") as HTMLTextAreaElement)?.value.trim();

				if (!name) {
					showError("name");
					isValid = false;
				}

				if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
					showError("email");
					isValid = false;
				}

				if (!subject) {
					showError("subject");
					isValid = false;
				}

				if (!message) {
					showError("message");
					isValid = false;
				}

				if (!isValid) {
					const firstError = form.querySelector('[id^="error-"]:not(.hidden)');
					firstError?.scrollIntoView({ behavior: "smooth", block: "center" });
				}

				return isValid;
			}

			form.addEventListener("submit", async (e) => {
				e.preventDefault();

				if (!validateForm()) return;

				const originalBtnHTML = submitBtn!.innerHTML;
				(submitBtn! as HTMLButtonElement).disabled = true;
				submitBtn!.innerHTML = `
					<svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
						<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
						<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
					</svg>
					${lang === "es" ? "Enviando..." : "Sending..."}
				`;

				successMsg?.classList.add("hidden");
				errorMsg?.classList.add("hidden");

				try {
					const formData = new FormData(form);

					// Send via email service (Mailgun configured in services)
					const { error } = await actions.contact(formData);

					if (error) {
						throw new Error(error.message || "Error al enviar");
					}

					// Success
					successMsg?.classList.remove("hidden");
					form.reset();
					successMsg?.scrollIntoView({ behavior: "smooth", block: "center" });
				} catch (err) {
					console.error("Contact form error:", err);
					errorMsg?.classList.remove("hidden");
					errorMsg?.scrollIntoView({ behavior: "smooth", block: "center" });
				} finally {
					(submitBtn! as HTMLButtonElement).disabled = false;
					submitBtn!.innerHTML = originalBtnHTML;
				}
			});
		});
	</script>
</BaseLayout>
