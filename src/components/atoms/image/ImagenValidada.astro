---
import ImagenBase from "./ImagenBase.astro";
import { validateImageSource } from "@/adapters/image/image.adapter";

interface Props {
	src: string;
	alt: string;
	loading?: "lazy" | "eager" | null | undefined;
	[key: string]: any;
}

const { src, alt } = Astro.props;
const safeSrc = validateImageSource(src);
---

<ImagenBase src={safeSrc} alt={alt} />
