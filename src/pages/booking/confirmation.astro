---
// pages/booking/confirmation.astro

import BaseLayout from "@/layouts/BaseLayout.astro";
import { Translations } from "@/i18n/translation.ts";
import { api } from "@/services/api.ts";
import type { SiteConfig } from "@/types/config";

const lang = Astro.url.pathname.startsWith("/en") ? "en" : "es";

const config = (await api.fetch("config", { params: { lang } })) as SiteConfig;

// Obtener datos de la URL (query params)
const bookingNumber = Astro.url.searchParams.get("booking") || "";
const checkin = Astro.url.searchParams.get("checkin") || "";
const checkout = Astro.url.searchParams.get("checkout") || "";
const nights = Astro.url.searchParams.get("nights") || "";
const adults = Astro.url.searchParams.get("adults") || "2";
const children = Astro.url.searchParams.get("children") || "0";
const rooms = Astro.url.searchParams.get("rooms") || "1";
const totalPrice = Astro.url.searchParams.get("total") || "";

const texts = {
	es: {
		title: "¡Reserva Confirmada!",
		subtitle: "Gracias por confiar en Hotel Ensueños",
		bookingNumber: "Número de Reserva",
		details: "Detalles de tu Reserva",
		checkin: "Fecha de Llegada",
		checkout: "Fecha de Salida",
		nights: "Noches",
		guests: "Huéspedes",
		adults: "Adultos",
		children: "Niños",
		rooms: "Habitaciones",
		totalPrice: "Precio Total",
		nextSteps: "Próximos Pasos",
		nextStepsText: "Hemos enviado un correo de confirmación a tu email. Nos pondremos en contacto contigo dentro de las próximas 24 horas para confirmar la disponibilidad.",
		whatsapp: "¿Tienes preguntas?",
		whatsappText: "Escríbenos por WhatsApp para cualquier consulta",
		contact: "Contáctanos",
		email: "Email",
		phone: "Teléfono",
		backToHome: "Volver al Inicio",
		viewBooking: "Ver mi reserva",
	},
	en: {
		title: "Booking Confirmed!",
		subtitle: "Thank you for trusting Ensueños Hotel",
		bookingNumber: "Booking Number",
		details: "Booking Details",
		checkin: "Check-in Date",
		checkout: "Check-out Date",
		nights: "Nights",
		guests: "Guests",
		adults: "Adults",
		children: "Children",
		rooms: "Rooms",
		totalPrice: "Total Price",
		nextSteps: "Next Steps",
		nextStepsText: "We have sent a confirmation email to your email address. We will contact you within the next 24 hours to confirm availability.",
		whatsapp: "Have questions?",
		whatsappText: "Write to us on WhatsApp for any inquiries",
		contact: "Contact Us",
		email: "Email",
		phone: "Phone",
		backToHome: "Back to Home",
		viewBooking: "View my booking",
	},
};

const currentTexts = texts[lang as "es" | "en"] || texts.es;
---

<BaseLayout
	titleKey="booking.confirmation"
	lang={lang}
	config={config}
	headerBgClass="text-gray-900"
>
	<!-- Hero Section -->
	<section class="relative bg-gradient-to-br from-accent to-accent/80 py-16 md:py-24">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<div class="inline-flex items-center justify-center w-20 h-20 bg-white/20 rounded-full mb-6 backdrop-blur-sm">
				<svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
				</svg>
			</div>
			<h1 class="text-4xl md:text-5xl font-serif text-white font-bold mb-4">
				{currentTexts.title}
			</h1>
			<p class="text-xl text-white/90">
				{currentTexts.subtitle}
			</p>
		</div>
	</section>

	<!-- Confirmation Content -->
	<section class="py-16 md:py-24 bg-gray-50">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<!-- Booking Number -->
			<div class="text-center mb-12">
				<p class="text-sm text-gray-600 uppercase tracking-wider mb-2">
					{currentTexts.bookingNumber}
				</p>
				<p class="text-3xl md:text-4xl font-bold text-primary font-mono">
					{bookingNumber || "RES-XXXXXXXX-XXXX"}
				</p>
				<p class="text-sm text-gray-500 mt-2">
					{lang === "es" ? "Guarda este número para tu referencia" : "Save this number for your reference"}
				</p>
			</div>

			<!-- Booking Details Card -->
			<div class="bg-white rounded-2xl shadow-xl overflow-hidden mb-12">
				<div class="bg-gradient-to-r from-primary to-primary/90 text-white px-6 py-4">
					<h2 class="text-2xl font-bold">
						{currentTexts.details}
					</h2>
				</div>
				
				<div class="p-6 md:p-8">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<div class="border-b border-gray-100 pb-4">
							<p class="text-sm text-gray-500 uppercase tracking-wider mb-1">
								{currentTexts.checkin}
							</p>
							<p class="text-xl font-semibold text-primary">
								{checkin || "—"}
							</p>
						</div>
						
						<div class="border-b border-gray-100 pb-4">
							<p class="text-sm text-gray-500 uppercase tracking-wider mb-1">
								{currentTexts.checkout}
							</p>
							<p class="text-xl font-semibold text-primary">
								{checkout || "—"}
							</p>
						</div>
						
						<div class="border-b border-gray-100 pb-4">
							<p class="text-sm text-gray-500 uppercase tracking-wider mb-1">
								{currentTexts.nights}
							</p>
							<p class="text-xl font-semibold text-primary">
								{nights || "—"}
							</p>
						</div>
						
						<div class="border-b border-gray-100 pb-4">
							<p class="text-sm text-gray-500 uppercase tracking-wider mb-1">
								{currentTexts.rooms}
							</p>
							<p class="text-xl font-semibold text-primary">
								{rooms}
							</p>
						</div>
						
						<div class="border-b border-gray-100 pb-4">
							<p class="text-sm text-gray-500 uppercase tracking-wider mb-1">
								{currentTexts.adults}
							</p>
							<p class="text-xl font-semibold text-primary">
								{adults}
							</p>
						</div>
						
						<div class="border-b border-gray-100 pb-4">
							<p class="text-sm text-gray-500 uppercase tracking-wider mb-1">
								{currentTexts.children}
							</p>
							<p class="text-xl font-semibold text-primary">
								{children}
							</p>
						</div>
					</div>
					
					{totalPrice && (
						<div class="mt-8 pt-6 border-t-2 border-accent">
							<div class="flex justify-between items-center">
								<span class="text-lg font-medium text-gray-700">
									{currentTexts.totalPrice}
								</span>
								<span class="text-3xl font-bold text-accent">
									${totalPrice}
								</span>
							</div>
						</div>
					)}
				</div>
			</div>

			<!-- Next Steps -->
			<div class="bg-white rounded-xl shadow-lg p-6 md:p-8 mb-12">
				<h3 class="text-2xl font-bold text-primary mb-4">
					{currentTexts.nextSteps}
				</h3>
				<p class="text-gray-700 leading-relaxed mb-6">
					{currentTexts.nextStepsText}
				</p>
				
				<div class="flex flex-col sm:flex-row gap-4">
					<a
						href={`https://wa.me/${config?.contactInfo?.whatsapp?.replace('+', '')}`}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center justify-center gap-2 bg-green-500 text-white font-bold py-3 px-6 rounded-lg hover:bg-green-600 transition-all"
					>
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
							<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
						</svg>
						{currentTexts.whatsapp}
					</a>
					
					<a
						href={`mailto:${config?.contactInfo?.email}`}
						class="inline-flex items-center justify-center gap-2 bg-primary text-white font-bold py-3 px-6 rounded-lg hover:bg-primary/90 transition-all"
					>
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
						</svg>
						{currentTexts.email}
					</a>
				</div>
			</div>

			<!-- Contact Info -->
			<div class="text-center">
				<h4 class="text-lg font-bold text-primary mb-4">
					{currentTexts.contact}
				</h4>
				<div class="flex flex-col sm:flex-row justify-center gap-6 text-gray-600">
					<div class="flex items-center justify-center gap-2">
						<svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
						</svg>
						<span>{config?.contactInfo?.whatsapp}</span>
					</div>
					<div class="flex items-center justify-center gap-2">
						<svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
						</svg>
						<span>{config?.contactInfo?.email}</span>
					</div>
				</div>
			</div>

			<!-- Back to Home -->
			<div class="text-center mt-12">
				<a
					href="/"
					class="inline-flex items-center gap-2 text-primary font-semibold hover:text-accent transition-colors"
				>
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
					</svg>
					{currentTexts.backToHome}
				</a>
			</div>
		</div>
	</section>
</BaseLayout>
