---
import ImagenLocal from "./ImagenLocal.astro";
import ImagenValidada from "./ImagenValidada.astro";

interface Props {
	src: string;
	alt: string;
	loading?: "lazy" | "eager" | null | undefined;
	[key: string]: any;
}

const { src } = Astro.props;

const isRemote = typeof src === "string" && src.startsWith("http");
---

{isRemote ? (
<ImagenValidada {...Astro.props} />
	) : (
<ImagenLocal {...Astro.props} />
	)}
