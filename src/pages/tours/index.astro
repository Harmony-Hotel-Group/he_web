---
//pages/tours/index.astro

// export const prerender = false;

import { Translations } from "@/i18n/translation.ts";
import { logger } from "@/services/logger.ts";

interface Props {
	lang: string;
}

const { lang = "es" } = Astro.props;

const log = logger("tours");

import UnderConstructionPage from "@/components/pages/UnderConstructionPage.astro";

const t = Translations(lang);
log.info(`Rendering tours page with language: ${lang}`);
---

<UnderConstructionPage
        titleHead={t("nav.tours")}
        title={t("underConstruction.tours.title")}
        message={t("underConstruction.tours.message")}
        btnBackLabel={t("underConstruction.back")}
        lang={lang}
/>
