---
/**
 * SeoHead.astro - Componente unificado de SEO
 * 
 * Este componente consolida:
 * - Meta tags (title, description, keywords)
 * - OpenGraph / Facebook
 * - Twitter Cards
 * - JSON-LD Schema (Hotel/LocalBusiness)
 * 
 * Uso:
 * <SeoHead title="Habitaciones" description="..." />
 */
import { ClientRouter } from "astro:transitions";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  articleDate?: string;
  schemaType?: "business" | "product" | "article";
}

const {
  title,
  description = "Hotel Ensueños, tu refugio ideal en el corazón de Cuenca, Ecuador. Disfruta de habitaciones cómodas, servicios excepcionales y una ubicación inmejorable.",
  ogImage = "/open-graph.jpg",
  articleDate,
  schemaType = "business",
} = Astro.props;

// Construir URLs de forma segura
const siteUrl = Astro.site?.toString() 
  ? Astro.site.toString() 
  : import.meta.env.VERCEL_URL 
    ? `https://${import.meta.env.VERCEL_URL}` 
    : "https://hotelensuenos.com";

const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const socialImageURL = new URL(ogImage, siteUrl).href;

const siteTitle = `${title} • Hotel Ensueños`;

// JSON-LD Schema para Hotel
const hotelSchema = {
  "@context": "https://schema.org",
  "@type": "Hotel",
  "name": "Hotel Ensueños",
  "description": "Hotel boutique en el centro histórico de Cuenca, Ecuador",
  "url": siteUrl,
  "telephone": "+593-7-123-4567",
  "email": "reservas@hotelensuenos.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Calle Principal, Centro Histórico",
    "addressLocality": "Cuenca",
    "addressRegion": "Azuay",
    "addressCountry": "EC",
    "postalCode": "010101"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "-2.9005",
    "longitude": "-79.0059"
  },
  "checkinTime": "14:00",
  "checkoutTime": "12:00",
  "priceRange": "$$",
  "starRating": {
    "@type": "Rating",
    "ratingValue": "4"
  },
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "WiFi", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Desayuno", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Estacionamiento", "value": true }
  ],
  "image": [
    "https://hotelensuenos.com/images/hotel-facade.jpg",
    "https://hotelensuenos.com/images/rooms/suite1.jpg"
  ]
};

// Schema para LocalBusiness (alternativo)
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LodgingBusiness",
  "name": "Hotel Ensueños",
  "image": "https://hotelensuenos.com/images/hotel-facade.jpg",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Calle Principal, Centro Histórico",
    "addressLocality": "Cuenca",
    "addressRegion": "Azuay",
    "addressCountry": "EC"
  },
  "telephone": "+593-7-123-4567",
  "url": siteUrl,
  "priceRange": "$$"
};
---

<head>
  <!-- Global Metadata -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Sitemap -->
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Primary Meta Tags -->
  <title>{siteTitle}</title>
  <meta name="title" content={siteTitle} />
  <meta name="description" content={description} />
  <meta name="author" content="Hotel Ensueños" />
  
  <!-- Keywords - Hotel Ensueños, Cuenca, Ecuador -->
  <meta name="keywords" content="hotel, hoteles, hotel en cuenca, hotelecuador, reservas de hotel, habitaciones, suites, hospedaje, turismo, cuenca ecuador, centro historico, hotel boutique, alojamiento, hotel con wifi, hotel con desayuno, reservas online" />

  <!-- ViewTransitions -->
  <ClientRouter />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={articleDate ? "article" : "website"} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={socialImageURL} />
  <meta property="og:site_name" content="Hotel Ensueños" />
  <meta property="og:locale" content="es_EC" />

  {articleDate && (
    <meta property="article:author" content="Hotel Ensueños" />
    <meta property="article:published_time" content={articleDate} />
  )}

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={socialImageURL} />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(hotelSchema)} />
</head>
